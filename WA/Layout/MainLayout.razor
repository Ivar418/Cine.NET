@inherits LayoutComponentBase
@using WA.Theme
@inject WA.Services.LayoutStateService LayoutState

<MudThemeProvider Theme="@AppTheme.Dark" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    @if (LayoutState.ShowTopBar)
    {
        <TopBar />
    }

    <MudMainContent>

        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>

    </MudMainContent>

    @if (LayoutState.ShowFooter)
    {
        <Footer></Footer>
    }

    @if (LayoutState.ShowFab)
    {
        <MudFab StartIcon="@Icons.Material.Filled.Add"
                Color="Color.Primary"
                Style="position: fixed; bottom: 24px; right: 24px;" />
    }

</MudLayout>

@code {
    protected override void OnInitialized()
    {
        LayoutState.OnChange += () => InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LayoutState.OnChange -= StateHasChanged;
    }
}
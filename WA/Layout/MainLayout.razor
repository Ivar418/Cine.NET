@inherits LayoutComponentBase
@using WA.Theme
@inject WA.Services.LayoutStateService LayoutState

<MudThemeProvider Theme="@AppTheme.Dark" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Style="min-height: 100vh; display: flex; flex-direction: column;">

    @if (LayoutState.ShowTopBar)
    {
        <TopBar />
    }

    <MudMainContent Style="flex: 1;">
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>

    @if (LayoutState.ShowFooter)
    {
        <Footer></Footer>
    }

    @if (LayoutState.ShowFab)
    {
        <MudFab StartIcon="@Icons.Material.Filled.Add"
                Color="Color.Primary"
                Style="position: fixed; bottom: 24px; right: 24px;" />
    }

</MudLayout>
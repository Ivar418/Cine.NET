<MudAppBar Color="Color.Default"
           Elevation="1"
           Style="background-color: var(--mud-palette-appbar-background); color: white; height:110px; justify-content:center;">

    <div style="display:flex; align-items:center; padding-left:16px;">
        <a href="/" style="display:flex; align-items:center;">

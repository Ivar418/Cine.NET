@using MudBlazor
@using Microsoft.AspNetCore.Components.Routing

<MudPaper Class="topbar"
          Elevation="1"
          Square="true"
          Style="background-color: var(--mud-palette-primary); color: var(--mud-palette-primary-text);">

    <MudText Typo="Typo.h6">App</MudText>

    <MudSpacer />

    <NavLink href="/" Match="NavLinkMatch.All" class="navlink">
        <MudButton Color="Color.Inherit">Home</MudButton>
    </NavLink>

    <NavLink href="/users" class="navlink">
        <MudButton Color="Color.Inherit">Users</MudButton>
    </NavLink>
    
    <NavLink href="/componentssheet" class="navlink">
        <MudButton Color="Color.Inherit">Components sheet</MudButton>
    </NavLink>

</MudPaper>
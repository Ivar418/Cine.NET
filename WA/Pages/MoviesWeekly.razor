@page "/thisweek"
@using SharedLibrary.DTOs.Responses
@using WA.Services.Http.Interfaces
@inject IShowingApi ShowingApi
@inject IMovieApiClient MovieApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using WA.Layout
@layout MainLayout

<PageTitle>Movies Weekly</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <MudText Typo="Typo.h4" Style="font-weight: bold; color: #BB86FC;">This Week</MudText>
    <MudText Typo="Typo.h6" Style="color: #03DAC6;">Overview</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_loadError)
{
    <MudAlert Severity="Severity.Error">Failed to load data. Please try again.</MudAlert>
}
else
{
    <div class="weekly-schedule-container">
        <div class="weekly-header">
            @foreach (var day in _daysInWeek)
            {
                <div class="day-column-header">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="color: #BB86FC; font-weight: bold;">
                        @day.ToString("dddd")
                    </MudText>
                    <MudText Typo="Typo.caption" Align="Align.Center" Style="color: #888;">
                        @day.ToString("dd MMM")
                    </MudText>
                    <div class="header-line"></div>
                </div>
            }
        </div>

        <div class="weekly-grid">
            @foreach (var day in _daysInWeek)
            {
                var dayShowings = _showings
                    .Where(s => s.StartsAt.ToLocalTime().Date == day.Date)
                    .OrderBy(s => s.StartsAt)
                    .ToList();

                <div class="day-column">
                    @foreach (var showing in dayShowings)
                    {
                        var localStart = showing.StartsAt.ToLocalTime();
                        var posterUrl = GetPosterUrl(showing.MovieId);
                        var runtime = GetRuntime(showing.MovieId);
                        var genres = GetGenreNames(showing.MovieId);

                        <MudCard Elevation="4"
                                 Class="movie-card-weekly mb-3 clickable-card"
                                 @onclick="@(() => NavigateToShowingDetail(showing.MovieId, showing.Id))">
                            <div class="weekly-poster-wrap">
                                @if (!string.IsNullOrWhiteSpace(posterUrl))
                                {
                                    <MudImage Src="@posterUrl"
                                              Alt="@showing.MovieTitle"
                                              Class="weekly-poster" />
                                }
                                else
                                {
                                    <div class="weekly-poster-placeholder">
                                        <MudIcon Icon="@Icons.Material.Filled.Movie" Color="Color.Default" Size="Size.Large" />
                                        <MudText Typo="Typo.caption" Style="color: #666; margin-top: 4px;">
                                            Geen poster
                                        </MudText>
                                    </div>
                                }
                            </div>

                            <div class="weekly-title-bar">
                                <MudText Typo="Typo.subtitle2" Class="weekly-title">
                                    @showing.MovieTitle
                                </MudText>
                            </div>

                            <MudCardContent Class="weekly-details-panel">
                                <div class="weekly-meta-row">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Primary"
                                             Variant="Variant.Filled"
                                             Class="weekly-time-chip">
                                        @localStart.ToString("HH:mm")
                                    </MudChip>

                                    <MudText Typo="Typo.caption" Class="weekly-auditorium">
                                        Zaal @showing.AuditoriumId
                                    </MudText>
                                </div>

                                @if (genres.Any())
                                {
                                    <MudText Typo="Typo.caption" Class="weekly-info-text">
                                        @string.Join(", ", genres.Take(2))
                                    </MudText>
                                }

                                <div class="weekly-bottom-row">
                                    @if (runtime.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Class="weekly-info-text">
                                            @runtime min
                                        </MudText>
                                    }

                                    <MudText Typo="Typo.caption" Class="weekly-info-text">
                                        @(showing.Is3D ? "3D" : "2D")
                                    </MudText>
                                </div>
                            </MudCardContent>
                        </MudCard>
                    }

                    @if (dayShowings.Count == 0)
                    {
                        <div class="no-showings pa-4 d-flex align-center justify-center">
                            <MudText Typo="Typo.caption" Style="color: #555; font-style: italic;">Geen vertoningen</MudText>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .weekly-schedule-container {
        display: flex;
        flex-direction: column;
        background-color: #121212;
        padding: 20px;
        border-radius: 8px;
        overflow-x: auto;
        min-width: 100%;
    }

    .weekly-header {
        display: flex;
        min-width: max-content;
        margin-bottom: 20px;
        gap: 12px;
    }

    .day-column-header {
        flex: 0 0 200px;
        width: 200px;
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: rgba(187, 134, 252, 0.05);
        padding: 14px 0;
        border-radius: 8px 8px 0 0;
    }

    .header-line {
        width: 60%;
        height: 2px;
        background: #BB86FC;
        margin-top: 8px;
        border-radius: 2px;
    }

    .weekly-grid {
        display: flex;
        min-width: max-content;
        gap: 12px;
        align-items: flex-start;
    }

    .day-column {
        flex: 0 0 200px;
        width: 200px;
        display: flex;
        flex-direction: column;
        min-height: 260px;
        background-color: rgba(255, 255, 255, 0.02);
        padding: 8px;
        border-radius: 0 0 8px 8px;
    }

    .movie-card-weekly {
        background-color: #f0f0f0 !important;
        border-radius: 8px;
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        cursor: pointer;
        border: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
    }

    .movie-card-weekly:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
        background-color: #ffffff !important;
    }

    .clickable-card {
        cursor: pointer;
    }

    .weekly-card-inner {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .weekly-title-bar {
        background: #06283a;
        padding: 8px 10px;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .weekly-title {
        font-weight: 700;
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        font-size: 0.75rem;
        line-height: 1.2;
        text-align: center;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .weekly-poster-wrap {
        width: 100%;
        aspect-ratio: 2 / 3;
        background: #1a1a1a;
        overflow: hidden;
        position: relative;
    }

    .weekly-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .movie-card-weekly:hover .weekly-poster {
        transform: scale(1.05);
    }

    .weekly-poster-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #2a2a2a;
    }

    .weekly-details-panel {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 10px !important;
        background: #f7f7f7;
        flex-grow: 1;
    }

    .weekly-meta-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 4px;
    }

    .weekly-time-chip {
        font-weight: bold;
        font-size: 0.75rem !important;
        height: 24px !important;
    }

    .weekly-auditorium {
        color: #1b6aa5;
        font-weight: 600;
        font-size: 0.7rem;
    }

    .weekly-info-text {
        color: #555;
        font-size: 0.7rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .weekly-bottom-row {
        display: flex;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 4px;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .weekly-badge {
        align-self: flex-start;
        margin-top: 4px;
        font-size: 0.68rem;
        height: 20px;
    }

    .weekly-time-chip {
        font-size: 0.68rem;
        height: 20px;
    }

    .no-showings {
        min-height: 64px;
        border: 1px dashed #333;
        border-radius: 8px;
    }
</style>

@code {
    private List<ShowingDisplayResponse> _showings = new();
    private List<DateTime> _daysInWeek = new();
    private readonly Dictionary<int, string?> _posterUrlsByMovieId = new();
    private readonly Dictionary<int, int?> _runtimeByMovieId = new();
    private readonly Dictionary<int, List<string>> _genreNamesByMovieId = new();
    private bool _loading = true;
    private bool _loadError;

    protected override async Task OnInitializedAsync()
    {
        InitializeWeekDays();
        await LoadDataAsync();
    }

    private void InitializeWeekDays()
    {
        _daysInWeek.Clear();

        var today = DateTime.Today;
        int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
        var startOfWeek = today.AddDays(-1 * diff);

        for (int i = 0; i < 7; i++)
        {
            _daysInWeek.Add(startOfWeek.AddDays(i));
        }
    }

    private string? GetPosterUrl(int movieId)
    {
        return _posterUrlsByMovieId.TryGetValue(movieId, out var posterPath) && !string.IsNullOrWhiteSpace(posterPath)
            ? $"https://image.tmdb.org/t/p/w500{posterPath}"
            : null;
    }

    private int? GetRuntime(int movieId)
    {
        return _runtimeByMovieId.TryGetValue(movieId, out var runtime) ? runtime : null;
    }

    private List<string> GetGenreNames(int movieId)
    {
        return _genreNamesByMovieId.TryGetValue(movieId, out var genres) ? genres : [];
    }

    private void NavigateToShowingDetail(int movieId, int showingId)
    {
        Navigation.NavigateTo($"/showingdetail/{movieId}/{showingId}");
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = false;

        try
        {
            var allShowings = await ShowingApi.GetShowingDisplayAsync();

            var startDay = _daysInWeek.First().Date;
            var endDay = _daysInWeek.Last().Date.AddDays(1);

            _showings = allShowings
                .Where(s =>
                {
                    var localDate = s.StartsAt.ToLocalTime().Date;
                    return localDate >= startDay && localDate < endDay;
                })
                .OrderBy(s => s.StartsAt)
                .ToList();

            var movieIds = _showings.Select(s => s.MovieId).Distinct().ToList();

            foreach (var movieId in movieIds)
            {
                var movie = await MovieApi.GetMovieByIdAsync(movieId);
                _posterUrlsByMovieId[movieId] = movie?.PosterPath;
                _runtimeByMovieId[movieId] = movie?.Runtime;

                var genreNames = new List<string>();

                if (movie?.GenresIds != null)
                {
                    foreach (var genreId in movie.GenresIds)
                    {
                        var genre = await MovieApi.GetGenreByIdAsync(genreId, "nl");
                        if (genre != null)
                            genreNames.Add(genre.Name);
                    }
                }

                _genreNamesByMovieId[movieId] = genreNames;
            }
        }
        catch (Exception ex)
        {
            _loadError = true;
            Console.WriteLine($"Error loading data: {ex.Message}");
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
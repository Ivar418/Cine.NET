@page "/checkout/{ShowingId:int}"
@using Microsoft.AspNetCore.Components
@using System.Net.Http.Json
@using SharedLibrary.DTOs.Responses
@using WA.Models
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Small">

    <MudStepper @bind-ActiveIndex="step">

        <MudStep Label="Stoelen">

            <MudText>Stoelen placeholder (komt later)</MudText>

            <MudButton OnClick="@(()=>step++)">
                Volgende
            </MudButton>

        </MudStep>

        <MudStep Label="Tickets">

            @if (showing == null)
            {
                <MudProgressCircular Indeterminate="true"/>
            }
            else
            {

                @foreach (var seat in seats)
                {
                    <MudPaper Class="pa-4 mb-2">

                        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">

                            <MudText>
                                Rij @seat.Row Stoel @seat.SeatNumber
                            </MudText>

                            <MudSelect T="string" @bind-Value="seat.TicketType">

                                <MudSelectItem Value="@("Adult")">
                                    Adult €@(showing?.Prices.Adult ?? 0)
                                </MudSelectItem>

                                <MudSelectItem Value="@("Student")">
                                    Student €@(showing?.Prices.Student ?? 0)
                                </MudSelectItem>

                                <MudSelectItem Value="@("Child")">
                                    Child €@(showing?.Prices.Child ?? 0)
                                </MudSelectItem>

                                <MudSelectItem Value="@("Senior")">
                                    Senior €@(showing?.Prices.Senior ?? 0)
                                </MudSelectItem>

                            </MudSelect>

                        </MudStack>

                    </MudPaper>
                }

                <MudButton OnClick="@(()=>step++)">
                    Volgende
                </MudButton>

            }

        </MudStep>

        <MudStep Label="Overzicht">

            @foreach (var seat in seats)
            {
                <MudText>
                    Rij @seat.Row Stoel @seat.SeatNumber - @seat.TicketType
                </MudText>
            }

        </MudStep>

    </MudStepper>

</MudContainer>

@code {

    // Houdt bij in welke stap van de checkout we zitten (MudStepper)
    int step = 0;

    // Tijdelijke testdata voor geselecteerde stoelen
    // Later komt dit van de SeatSelector component / API
    List<TicketSelection> seats = new()
    {
        new TicketSelection{ Row = 3, SeatNumber = 6 },
        new TicketSelection{ Row = 3, SeatNumber = 7 }
    };

    // ShowingId komt uit de URL:
    // /checkout/2  → ShowingId = 2
    [Parameter]
    public int ShowingId { get; set; }

    // Hier slaan we de API response op
    // (filmnaam, starttijd, prijzen)
    private ShowingsWithPricesResponse? showing;

    // Wordt automatisch uitgevoerd wanneer de pagina laadt
    // Hier halen we de showing + prijzen op uit de API
    protected override async Task OnInitializedAsync()
    {
        showing = await Http.GetFromJsonAsync<ShowingsWithPricesResponse>(
            $"api/showings/{ShowingId}/prices"
        );
    }
}
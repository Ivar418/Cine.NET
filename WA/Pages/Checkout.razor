@page "/checkout/{ShowingId:int}"
@namespace WA.Pages

<MudContainer MaxWidth="MaxWidth.Small">

    <MudStepper @bind-ActiveIndex="step">

        <MudStep Label="Stoelen">

            <MudText>Stoelen placeholder (komt later)</MudText>

            <MudButton OnClick="@(()=>step++)">
                Volgende
            </MudButton>

        </MudStep>

        <MudStep Label="Tickets">

            @if (showing == null)
            {
                <MudProgressCircular Indeterminate="true"/>
            }
            else
            {
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6">@Summary.MovieTitle</MudText>
                    <MudText Typo="Typo.body2">@Summary.StartsAt.ToString("dddd d MMMM yyyy HH:mm")</MudText>
                </MudPaper>

                @foreach (var seat in seats)
                {
                    <MudPaper Class="pa-4 mb-2">

                        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">

                            <MudText>
                                Rij @seat.Row Stoel @seat.SeatNumber
                            </MudText>

                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudSelect T="string" @bind-Value="seat.TicketType">

                                    <MudSelectItem Value='@("Adult")'>
                                        Adult €@(showing?.Prices.Adult ?? 0)
                                    </MudSelectItem>

                                    <MudSelectItem Value='@("Student")'>
                                        Student €@(showing?.Prices.Student ?? 0)
                                    </MudSelectItem>

                                    <MudSelectItem Value='@("Child")'>
                                        Child €@(showing?.Prices.Child ?? 0)
                                    </MudSelectItem>

                                    <MudSelectItem Value='@("Senior")'>
                                        Senior €@(showing?.Prices.Senior ?? 0)
                                    </MudSelectItem>

                                </MudSelect>

                                <MudText Typo="Typo.body1">
                                    €@GetSeatPrice(seat)
                                </MudText>
                            </MudStack>

                        </MudStack>

                    </MudPaper>
                }

                <MudPaper Class="pa-4 mb-4">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Totaal</MudText>
                        <MudText Typo="Typo.h6">€@Summary.TotalPrice</MudText>
                    </MudStack>
                </MudPaper>

                <MudButton OnClick="@(()=>step++)" Disabled="@(!CanContinueToOverview)">
                    Volgende
                </MudButton>

            }

        </MudStep>

        <MudStep Label="Overzicht">

            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6">Boekingsoverzicht</MudText>
                <MudText Typo="Typo.body2">@Summary.MovieTitle</MudText>
                <MudText Typo="Typo.body2">@Summary.StartsAt.ToString("dddd d MMMM yyyy HH:mm")</MudText>
            </MudPaper>

            @foreach (var seat in Summary.Lines)
            {
                <MudPaper Class="pa-3 mb-2">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText>
                            Rij @seat.Row Stoel @seat.SeatNumber - @seat.TicketType
                        </MudText>
                        <MudText>
                            €@GetSeatPrice(seat)
                        </MudText>
                    </MudStack>
                </MudPaper>
            }

            <MudPaper Class="pa-4 mt-4">
                <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">Totaal</MudText>
                    <MudText Typo="Typo.h6">€@Summary.TotalPrice</MudText>
                </MudStack>
            </MudPaper>

        </MudStep>

    </MudStepper>

</MudContainer>
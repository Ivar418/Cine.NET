@page "/checkout/{ShowingId:int}"
@namespace WA.Pages
@using SharedLibrary.DTOs.Models
@using WA.Components
@using WA.Layout
@layout MainLayout
@inherits LocalizedComponentBase
@inject IStringLocalizer<WA.Localization.SharedResources> L

<MudContainer MaxWidth="MaxWidth.Large">

    @* ==== Step indicator ==== *@
    <MudStack Row Justify="Justify.Center" Spacing="2" Class="mt-4">
        <MudChip T="string" Color=@(step == 1 ? Color.Primary : Color.Default)>@L["seat_choice"]</MudChip>
        <MudChip T="string" Color=@(step == 2 ? Color.Primary : Color.Default)>@L["tickets"]</MudChip>
        <MudChip T="string" Color=@(step == 3 ? Color.Primary : Color.Default)>@L["overview"]</MudChip>
        <MudChip T="string" Color=@(step == 4 ? Color.Primary : Color.Default)>@L["choose_payment_type"]</MudChip>
        <MudChip T="string" Color=@(step == 5 ? Color.Primary : Color.Default)>@L["payment"]</MudChip>
    </MudStack>

    @if (step == 1)
    {
        <MudStack Spacing="4">

            @* ── Showing selector ──── *@
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.End" Spacing="3">

                    @if (isLoading)
                    {
                        <MudProgressCircular Indeterminate="true"/>
                    }
                    else if (errorMessage != null)
                    {
                        <MudAlert Severity="Severity.Warning">
                            @L["no_movies_found"]
                        </MudAlert>
                    }
                    else if (showing == null)
                    {
                        <MudAlert Severity="Severity.Info">
                            @L["no_movies_available"]
                        </MudAlert>
                    }
                    else
                    {
                        <MudPaper Class="pa-4 mb-4">
                            <MudText Typo="Typo.h6">@Summary.MovieTitle</MudText>
                            <MudText Typo="Typo.body2">@Summary.StartsAt.ToString("dddd d MMMM yyyy HH:mm")</MudText>
                        </MudPaper>
                    }

                    @if (_state is not null)
                    {
                        @* Normal tickets *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Style="letter-spacing:.1em;color:var(--mud-palette-text-secondary)">
                                🪑 @L["normal_seats"]
                            </MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="() => _normalCount = Math.Max(0, _normalCount - 1)"/>
                                <MudText Style="min-width:28px;text-align:center;font-weight:700;font-size:1.1rem">@_normalCount</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="() => _normalCount++"/>
                            </MudStack>
                        </MudStack>

                        @* Wheelchair tickets *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Style="letter-spacing:.1em;color:var(--mud-palette-text-secondary)">
                                ♿ @L["wheelchair_seats"]
                            </MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="() => _wcCount = Math.Max(0, _wcCount - 1)"/>
                                <MudText Style="min-width:28px;text-align:center;font-weight:700;font-size:1.1rem;color:#93c5fd">@_wcCount</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="() => _wcCount++"/>
                            </MudStack>
                        </MudStack>

                        @* Actions *@
                        <MudStack Row="true" Spacing="1" Class="ml-auto" AlignItems="AlignItems.Center">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="SuggestAsync" Disabled="@(_normalCount + _wcCount == 0 || _busy)">
                                @string.Format(L["search_seats"], (_normalCount + _wcCount), (_normalCount + _wcCount == 1 ? L["seat"] : L["seats"]))
                            </MudButton>
                            @if (_pendingId.HasValue)
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" OnClick="CancelPendingAsync">@L["cancel"]</MudButton>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>

            @* ── Seat grid ──── *@
            @if (_busy && _state is null)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
            }
            else if (_state is not null)
            {
                <MudPaper Elevation="2" Class="pa-3" Style="overflow-x:auto">
                    <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Material.Filled.Movie">@_state.Showing.Movie.Title</MudChip>
                        <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Material.Filled.Schedule">@_state.Showing.StartsAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")</MudChip>
                        <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Material.Filled.EventSeat">@_state.Showing.Auditorium.Name</MudChip>
                        <MudSpacer/>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
                            @string.Format(L["free_spots"], (_state.AllSeats.Count - _state.OccupiedKeys.Count))
                        </MudText>
                    </MudStack>

                    <SeatGrid Auditorium="@(new AuditoriumDto(_state.Showing.Auditorium.Id, _state.Showing.Auditorium.Name, _state.Showing.GetLayoutSnapshot()))"
                              AllSeats="@_state.AllSeats"
                              OccupiedKeys="@_state.OccupiedKeys"
                              SuggestedKeys="@_suggestedKeys"
                              ShowZones="@_showZones"
                              OnSeatClick="HandleSeatClickAsync" />
                </MudPaper>
            }
            else if (_ShowingId.HasValue)
            {
                <MudAlert Severity="Severity.Warning">@L["cannot_load_showing"]</MudAlert>
            }
            else
            {
                <MudPaper Elevation="1" Class="pa-6" Style="text-align:center">
                    <MudText Style="color:var(--mud-palette-text-secondary);letter-spacing:.15em">
                        @L["select_showing_to_start"]
                    </MudText>
                </MudPaper>
            }

            @* ── Legend ──── *@
            @if (_state is not null)
            {
                <MudPaper Elevation="1" Class="pa-3">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Justify="Justify.Center">
                        @foreach (var (label, color) in _legend)
                        {
                            <MudChip T="string" Size="Size.Small" Style="@($"background:{color}22;border:1px solid {color}66;color:{color};font-size:.65rem")">
                                @label
                            </MudChip>
                        }
                    </MudStack>
                </MudPaper>
            }

        </MudStack>
        <MudButton Style="float:right" Variant="Variant.Filled" Color="Color.Success" OnClick="@(async () => { SetStep(2); await ConfirmAsync(); })" Disabled="@(_state == null || _pendingId == null)">
            @L["confirm"]
        </MudButton>
    }

    @if (step == 2)
    {
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true"/>
        }
        else if (errorMessage != null)
        {
            <MudAlert Severity="Severity.Warning">@L["no_movies_found"]</MudAlert>
        }
        else if (showing == null)
        {
            <MudAlert Severity="Severity.Info">@L["no_movies_available"]</MudAlert>
        }
        else
        {
            <MudPaper Class="pa-4 mb-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">@Summary.MovieTitle</MudText>
                    <MudText Typo="Typo.body2">@Summary.StartsAt.ToString("dddd d MMMM yyyy HH:mm")</MudText>
                    <MudStack Row="true" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="() => OnShowingChangedAsync(ShowingId)">@L["cancel"]</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            @foreach (var seat in seats)
            {
                <MudPaper Class="pa-4 mb-2">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText>@L["row"] @seat.Row @L["seat_label"] @seat.SeatNumber</MudText>
                        <MudSelect T="string" @bind-Value="seat.TicketType" Dense="true">
                            <MudSelectItem Value=@("Adult") Disabled="@(!showing.Prices.Adult.IsAvailable)">Adult €@showing.Prices.Adult.Price</MudSelectItem>
                            <MudSelectItem Value=@("Student") Disabled="@(!showing.Prices.Student.IsAvailable)">Student €@showing.Prices.Student.Price</MudSelectItem>
                            <MudSelectItem Value=@("Child") Disabled="@(!showing.Prices.Child.IsAvailable)">Child €@showing.Prices.Child.Price</MudSelectItem>
                            <MudSelectItem Value=@("Senior") Disabled="@(!showing.Prices.Senior.IsAvailable)">Senior €@showing.Prices.Senior.Price</MudSelectItem>
                        </MudSelect>
                        <MudText Typo="Typo.body1">€@GetSeatPrice(seat)</MudText>
                    </MudStack>
                </MudPaper>
            }
        }

        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2 d-block">
            <MudList T="object" Dense="true">
                <MudListItem T="object">
                    <MudText>@L["price_info_standard"]</MudText>
                    <MudText Typo="Typo.caption" Style="font-style: italic;" Class="text-muted">@L["price_info_long_movie"]</MudText>
                </MudListItem>
                <MudListItem T="object">
                    <MudText>@L["price_info_child"]</MudText>
                    <MudText Typo="Typo.caption" Style="font-style: italic;" Class="text-muted">@L["price_info_child_sub"]</MudText>
                </MudListItem>
                <MudListItem T="object">
                    <MudText>@L["price_info_student"]</MudText>
                    <MudText Typo="Typo.caption" Style="font-style: italic;" Class="text-muted">@L["price_info_student_sub"]</MudText>
                </MudListItem>
                <MudListItem T="object">
                    <MudText>@L["price_info_senior"]</MudText>
                    <MudText Typo="Typo.caption" Style="font-style: italic;" Class="text-muted">@L["price_info_senior_sub"]</MudText>
                </MudListItem>
                <MudListItem T="object">
                    <MudText>@L["price_info_3d"]</MudText>
                </MudListItem>
            </MudList>
        </MudAlert>

        <MudButton Style="float:right" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => SetStep(3))" Disabled="@seats.Any(s => s.TicketType == null)">
            @L["next"]
        </MudButton>
    }

    @if (step == 3)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">@L["booking_overview"]</MudText>
                <MudText Typo="Typo.body2">@Summary.MovieTitle</MudText>
                <MudText Typo="Typo.body2">@Summary.StartsAt.ToString("dddd d MMMM yyyy HH:mm")</MudText>
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="() => OnShowingChangedAsync(ShowingId)">@L["cancel"]</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @foreach (var seat in seats)
        {
            <MudText>@L["row"] @seat.Row @L["seat_label"] @seat.SeatNumber - @seat.TicketType</MudText>
        }

        <MudPaper Class="pa-4 mt-4">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">@L["total"]</MudText>
                <MudText Typo="Typo.h6">€@Summary.TotalPrice</MudText>
            </MudStack>
        </MudPaper>

        <MudButton Style="float:right" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SetStep(4))">
            @L["confirm"]
        </MudButton>
    }

    @if (step == 4)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">@L["choose_payment_method"]</MudText>
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="() => OnShowingChangedAsync(ShowingId)">@L["cancel"]</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
        <MudStack Row="true" Spacing="3" Style="width:100%;">
            @foreach (var paymentMethod in paymentMethods)
            {
                <MudButton Style="flex:1;" OnClick="@(() => { SetStep(5); SelectPaymentMethod(paymentMethod); })">
                    <MudPaper Class="pa-4" Style="width:100%; cursor:pointer">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@paymentIcons[paymentMethod]" Size="Size.Large"/>
                            <MudText>@L[$"payment_method_{paymentMethod}"]</MudText>
                        </MudStack>
                    </MudPaper>
                </MudButton>
            }
        </MudStack>
    }

    @if (step == 5)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">@L["confirm_order"]</MudText>
                <MudText Typo="Typo.body2">@L["payment_method"]: <strong>@L[$"payment_method_{selectedPaymentMethod}"]</strong></MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Class="mb-2">@Summary.MovieTitle</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">@Summary.StartsAt.ToString("dddd d MMMM yyyy HH:mm")</MudText>
            @foreach (var seat in seats)
            {
                <MudText Typo="Typo.body2">
                    @L["row"] @seat.Row · @L["seat_label"] @seat.SeatNumber · @seat.TicketType · €@GetSeatPrice(seat).ToString("F2")
                </MudText>
            }
            <MudDivider Class="my-3"/>
            <MudStack Row Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">@L["total"]</MudText>
                <MudText Typo="Typo.h6">€@Summary.TotalPrice.ToString("F2")</MudText>
            </MudStack>
        </MudPaper>

        <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="() => step = 4" Disabled="@_orderBusy">
                ← @L["back"]
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="@(selectedPaymentMethod == "Reserveren" ? Color.Success : Color.Primary)" OnClick="ProcessOrderAsync" Disabled="@_orderBusy" StartIcon="@(selectedPaymentMethod == "Reserveren" ? Icons.Material.Filled.BookmarkAdd : Icons.Material.Filled.Payment)">
                @if (_orderBusy)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                    <text>@L["processing"]</text>
                }
                else if (selectedPaymentMethod == "Reserveren")
                {
                    <text>@L["confirm_reservation"]</text>
                }
                else
                {
                    <text>@L["proceed_to_payment"]</text>
                }
            </MudButton>
        </MudStack>
    }

</MudContainer>
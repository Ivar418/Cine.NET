@page "/today"
@using SharedLibrary.DTOs.Responses
@using SharedLibrary.Domain.Entities
@using WA.Services.Http.Interfaces
@inject IShowingApi ShowingApi
@inject IAuditoriumApi AuditoriumApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using WA.Layout
@layout MainLayout

<PageTitle>Movies Today</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <MudText Typo="Typo.h4" Style="font-weight: bold; color: #BB86FC;">Movies Today</MudText>
    <MudText Typo="Typo.h6" Style="color: #03DAC6;">@DateTime.Now.ToString("dddd, dd MMMM yyyy HH:mm")</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_loadError)
{
    <MudAlert Severity="Severity.Error">Failed to load data. Please try again.</MudAlert>
}
else
{
    <div class="schedule-container">
        <div class="schedule-header">
            <div class="time-column-header"></div>
            @foreach (var auditorium in _auditoriums.OrderBy(a => a.Name))
            {
                <div class="auditorium-column-header">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="color: #BB86FC; font-weight: bold;">@auditorium.Name</MudText>
                    <div class="header-line"></div>
                </div>
            }
        </div>

        <div class="schedule-grid">
            @{
                var now = DateTimeOffset.Now;
                var currentTimeOffset = CalculateTopOffset(now);

                if (currentTimeOffset >= 0 && currentTimeOffset <= 880)
                {
                    <div class="current-time-line" style="top: @(currentTimeOffset)px;"></div>
                }
            }

            <div class="time-column">
                @for (int hour = 12; hour <= 22; hour++)
                {
                    <div class="time-slot">
                        <MudText Typo="Typo.caption" Style="color: #3f51b5;">@($"{hour}:00")</MudText>
                    </div>
                }
            </div>

            @foreach (var auditorium in _auditoriums.OrderBy(a => a.Name))
            {
                <div class="auditorium-column">
                    @for (int hour = 12; hour <= 22; hour++)
                    {
                        <div class="grid-line"></div>
                    }

                    @foreach (var showing in _showings
                        .Where(s => s.AuditoriumId == auditorium.Id)
                        .OrderBy(s => s.StartsAt))
                    {
                        var localStart = showing.StartsAt.ToLocalTime();
                        var topOffset = CalculateTopOffset(localStart);
                        var height = CalculateHeight(showing.Runtime);

                        <div class="movie-card-container" style="top: @(topOffset)px; height: @(height)px;">
                            <MudCard Elevation="4" Class="movie-card">
                                <MudCardContent Class="pa-2">
                                    <div class="d-flex">
                                        <div class="flex-grow-1">
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: bold; font-size: 0.8rem;">
                                                @showing.MovieTitle
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="d-block mt-1" Style="color: #444; font-weight: 500;">
                                                Start: @localStart.ToString("HH:mm")
                                            </MudText>

                                            <MudText Typo="Typo.caption" Class="d-block mt-1" Style="color: #444; font-weight: 500;">
                                                Runtime: @(showing.Runtime ?? 0)m
                                            </MudText>

                                            <div class="d-flex align-center mt-auto pt-2">
                                                <div class="status-dot @GetStatusClass(showing)"></div>
                                                <MudText Typo="Typo.caption" Style="font-size: 0.7rem; margin-left: 4px; color: #333;">
                                                    @GetStatusText(showing)
                                                </MudText>
                                            </div>
                                        </div>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .schedule-container {
        display: flex;
        flex-direction: column;
        background-color: #121212;
        padding: 20px;
        border-radius: 8px;
        overflow-x: auto;
        min-width: 100%;
    }

    .schedule-header {
        display: inline-flex;
        min-width: 100%;
        margin-bottom: 10px;
    }

    .time-column-header {
        width: 60px;
        flex-shrink: 0;
        position: sticky;
        left: 0;
        background-color: #121212;
        z-index: 30;
    }

    .auditorium-column-header {
        flex: 0 0 250px;
        width: 250px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .header-line {
        width: 80%;
        height: 2px;
        background: repeating-linear-gradient(to right, #BB86FC 0, #BB86FC 4px, transparent 4px, transparent 8px);
        margin-top: 8px;
    }

    .schedule-grid {
        display: inline-flex;
        min-width: 100%;
        position: relative;
        min-height: 1000px;
    }

    .current-time-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background-color: #03DAC6;
        z-index: 20;
        pointer-events: none;
    }

    .current-time-line::before {
        content: "";
        position: absolute;
        left: 55px;
        top: -4px;
        width: 10px;
        height: 10px;
        background-color: #03DAC6;
        border-radius: 50%;
    }

    .time-column {
        width: 60px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        position: sticky;
        left: 0;
        background-color: #121212;
        z-index: 30;
    }

    .time-slot {
        height: 80px;
        border-right: 1px solid #333;
        display: flex;
        justify-content: center;
        padding-top: 4px;
    }

    .auditorium-column {
        flex: 0 0 250px;
        width: 250px;
        position: relative;
        border-right: 1px solid #333;
    }

    .grid-line {
        height: 80px;
        border-bottom: 1px dashed #333;
    }

    .movie-card-container {
        position: absolute;
        left: 5px;
        right: 5px;
        z-index: 10;
    }

    .movie-card {
        background-color: #D1D5DB !important;
        color: #121212 !important;
        height: 100%;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .status-available { background-color: #4CAF50; }
    .status-few { background-color: #FFEB3B; }
    .status-soldout { background-color: #F44336; }
</style>

@code {
    private List<ShowingsWithPricesResponse> _showings = new();
    private List<Auditorium> _auditoriums = new();
    private bool _loading = true;
    private bool _loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = false;

        try
        {
            var auditoriumTask = AuditoriumApi.GetAllAuditoriumsAsync();
            var showingTask = ShowingApi.GetShowingsWithPricesAsync();

            await Task.WhenAll(auditoriumTask, showingTask);

            _auditoriums = auditoriumTask.Result ?? new List<Auditorium>();
            var allShowings = showingTask.Result ?? new List<ShowingsWithPricesResponse>();

            var today = DateTimeOffset.Now.Date;
            _showings = allShowings
                .Where(s => s.StartsAt.ToLocalTime().Date == today)
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError = true;
            Console.WriteLine($"Error loading data: {ex.Message}");
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private double CalculateTopOffset(DateTimeOffset dateTime)
    {
        var localTime = dateTime.ToLocalTime();
        var startHour = 12.0;
        var hourValue = localTime.Hour + (localTime.Minute / 60.0);
        var diff = hourValue - startHour;

        return Math.Max(0, diff * 80.0);
    }

    private double CalculateHeight(int? runtimeMinutes)
    {
        if (!runtimeMinutes.HasValue || runtimeMinutes == 0) return 120;
        return Math.Max(100.0, (runtimeMinutes.Value / 60.0) * 80.0);
    }

    private string GetStatusClass(ShowingsWithPricesResponse showing)
    {
        return "status-available";
    }

    private string GetStatusText(ShowingsWithPricesResponse showing)
    {
        return "Seats available";
    }
}

@page "/MoviesToday"
@using SharedLibrary.DTOs.Responses
@using SharedLibrary.Domain.Entities
@using WA.Services.Http.Interfaces
@inject IMovieApiClient MovieApiClient
@inject IShowingApi ShowingApi
@inject IAuditoriumApi AuditoriumApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using WA.Layout
@layout AdminLayout

<PageTitle>Movies Today</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <MudText Typo="Typo.h4" Style="font-weight: bold; color: #BB86FC;">Movies Today</MudText>
    <MudText Typo="Typo.h6" Style="color: #03DAC6;">@DateTime.Now.ToString("dddd, MMMM do, yyyy HH:mm")</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_loadError)
{
    <MudAlert Severity="Severity.Error">Failed to load data. Please try again.</MudAlert>
}
else
{
    <div class="schedule-container">
        @* Header rij met zalen *@
        <div class="schedule-header">
            <div class="time-column-header"></div>
            @foreach (var auditorium in _auditoriums.OrderBy(a => a.Name))
            {
                <div class="auditorium-column-header">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="color: #BB86FC; font-weight: bold;">@auditorium.Name</MudText>
                    <div class="header-line"></div>
                </div>
            }
        </div>

        @* Rooster inhoud *@
        <div class="schedule-grid">
            @* Tijdlijn voor huidige tijd *@
            @{
                // Gebruik DateTimeOffset.Now voor de offset berekening
                var now = DateTimeOffset.Now;
                var currentTimeOffset = CalculateTopOffset(now);
                
                // Alleen tonen tussen 12:00 en 23:00 (0 tot 880px)
                if (currentTimeOffset >= 0 && currentTimeOffset <= 880)
                {
                    <div class="current-time-line" style="top: @(currentTimeOffset)px;"></div>
                }
            }
            
            @* Tijd kolom *@
            <div class="time-column">
                @for (int hour = 12; hour <= 22; hour++)
                {
                    <div class="time-slot">
                        <MudText Typo="Typo.caption" Style="color: #3f51b5;">@($"{hour}:00")</MudText>
                    </div>
                }
            </div>

            @* Zalen kolommen *@
            @foreach (var auditorium in _auditoriums.OrderBy(a => a.Name))
            {
                <div class="auditorium-column">
                    @* Hulplijnen voor uren *@
                    @for (int hour = 12; hour <= 22; hour++)
                    {
                        <div class="grid-line"></div>
                    }

            @* Vertoningen *@
                    @foreach (var showing in _showings.Where(s => s.AuditoriumId == auditorium.Id))
                    {
                        var topOffset = CalculateTopOffset(showing.StartsAt);
                        var height = CalculateHeight(showing.Runtime);

                        <div class="movie-card-container" style="top: @(topOffset)px; height: @(height)px;">
                            <MudCard Elevation="4" Class="movie-card">
                                <MudCardContent Class="pa-2">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: bold; font-size: 0.8rem;">@showing.MovieTitle</MudText>
                                    
                                    @if (showing.AuditoriumId == 1 && showing.MovieTitle == "Movie title")
                                    {
                                        <div class="movie-content-with-poster">
                                            <div class="poster-placeholder">
                                                <img src="https://image.tmdb.org/t/p/w200/ovM0BgeFz4vEKCDghSRp7COZ9vY.jpg" alt="Poster" />
                                            </div>
                                            <div class="movie-tags">
                                                <span class="tag tag-horror">Horror • Thriller</span>
                                                <span class="tag tag-age">16+ | 150m</span>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Class="d-block mt-1" Style="color: #444; font-weight: 500;">Horror, Thriller</MudText>
                                        <MudText Typo="Typo.caption" Class="d-block" Style="color: #444; font-weight: 500;">Age: 16+ | @(showing.Runtime)m</MudText>
                                    }
                                    
                                    @* Voorbeeld van status indicator zoals in afbeelding *@
                                    <div class="d-flex align-center mt-auto pt-2">
                                        <div class="status-dot @GetStatusClass(showing)"></div>
                                        <MudText Typo="Typo.caption" Style="font-size: 0.7rem; margin-left: 4px; color: #333;">@GetStatusText(showing)</MudText>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .schedule-container {
        display: flex;
        flex-direction: column;
        background-color: #121212;
        padding: 20px;
        border-radius: 8px;
        overflow-x: auto;
        min-width: 100%;
    }

    .schedule-header {
        display: inline-flex;
        min-width: 100%;
        margin-bottom: 10px;
    }

    .time-column-header {
        width: 60px;
        flex-shrink: 0;
        position: sticky;
        left: 0;
        background-color: #121212;
        z-index: 30;
    }

    .auditorium-column-header {
        flex: 0 0 200px;
        width: 200px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .header-line {
        width: 80%;
        height: 2px;
        background: repeating-linear-gradient(to right, #BB86FC 0, #BB86FC 4px, transparent 4px, transparent 8px);
        margin-top: 8px;
    }

    .schedule-grid {
        display: inline-flex;
        min-width: 100%;
        position: relative;
        min-height: 1000px;
    }

    .current-time-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background-color: #03DAC6;
        z-index: 20;
        pointer-events: none;
    }

    .current-time-line::before {
        content: "";
        position: absolute;
        left: 55px;
        top: -4px;
        width: 10px;
        height: 10px;
        background-color: #03DAC6;
        border-radius: 50%;
    }

    .time-column {
        width: 60px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        position: sticky;
        left: 0;
        background-color: #121212;
        z-index: 30;
    }

    .time-slot {
        height: 80px;
        border-right: 1px solid #333;
        display: flex;
        justify-content: center;
        padding-top: 4px;
    }

    .auditorium-column {
        flex: 0 0 200px;
        width: 200px;
        position: relative;
        border-right: 1px solid #333;
    }

    .grid-line {
        height: 80px;
        border-bottom: 1px dashed #333;
    }

    .movie-card-container {
        position: absolute;
        left: 5px;
        right: 5px;
        z-index: 10;
    }

    .movie-card {
        background-color: #D1D5DB !important;
        color: #121212 !important;
        height: 100%;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .movie-content-with-poster {
        display: flex;
        flex-direction: row;
        gap: 8px;
        margin-top: 4px;
        height: 120px;
    }

    .poster-placeholder {
        width: 80px;
        height: 110px;
        background-color: #333;
        border-radius: 6px;
        overflow: hidden;
    }

    .poster-placeholder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .movie-tags {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 4px;
        flex: 1;
    }

    .tag {
        font-size: 0.6rem;
        padding: 2px 6px;
        border-radius: 4px;
        white-space: nowrap;
        width: fit-content;
    }

    .tag-horror {
        background-color: #7B1FA2;
        color: white;
    }

    .tag-age {
        background-color: #4A148C;
        color: white;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .status-available { background-color: #4CAF50; }
    .status-few { background-color: #FFEB3B; }
    .status-soldout { background-color: #F44336; }
</style>

@code {
    private List<ShowingsWithPricesResponse> _showings = new();
    private List<Auditorium> _auditoriums = new();
    private bool _loading = true;
    private bool _loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = false;

        try
        {
            var audTask = AuditoriumApi.GetAllAuditoriumsAsync();
            var showingTask = ShowingApi.GetShowingsWithPricesAsync();

            await Task.WhenAll(audTask, showingTask);

            _auditoriums = audTask.Result ?? new();
            _showings = showingTask.Result?.ToList() ?? new();

            // Als er geen data is, vul aan met placeholders om het ontwerp te tonen zoals gevraagd
            if (_auditoriums.Count == 0)
            {
                for (int i = 1; i <= 6; i++)
                {
                    _auditoriums.Add(new Auditorium { Id = i, Name = $"Zaal {i}" });
                }

                // Voeg placeholder showings toe gebaseerd op de afbeelding
                var today = DateTimeOffset.Now.Date;
                
                // Zaal 1: Film met poster
                _showings.Add(new ShowingsWithPricesResponse 
                { 
                    ShowingId = 1, 
                    MovieTitle = "Movie title", 
                    AuditoriumId = 1, 
                    Runtime = 150, 
                    StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 15, 0, 0, TimeSpan.Zero)
                });

                // Zaal 2: Few seats
                _showings.Add(new ShowingsWithPricesResponse 
                { 
                    ShowingId = 2, 
                    MovieTitle = "Movie title", 
                    AuditoriumId = 2, 
                    Runtime = 150, 
                    StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 15, 0, 0, TimeSpan.Zero)
                });

                // Zaal 3: Sold out
                _showings.Add(new ShowingsWithPricesResponse 
                { 
                    ShowingId = 3, 
                    MovieTitle = "Movie title", 
                    AuditoriumId = 3, 
                    Runtime = 150, 
                    StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 17, 0, 0, TimeSpan.Zero)
                });

                // Zaal 4: Sold out (vroeger)
                _showings.Add(new ShowingsWithPricesResponse 
                { 
                    ShowingId = 6, 
                    MovieTitle = "Movie title", 
                    AuditoriumId = 4, 
                    Runtime = 150, 
                    StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 12, 30, 0, TimeSpan.Zero)
                });

                // Zaal 5: Sold out
                _showings.Add(new ShowingsWithPricesResponse 
                { 
                    ShowingId = 9, 
                    MovieTitle = "Movie title", 
                    AuditoriumId = 5, 
                    Runtime = 150, 
                    StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 14, 30, 0, TimeSpan.Zero)
                });
            }
        }
        catch (Exception)
        {
            // Zelfs bij error tonen we placeholders voor de demo
            _auditoriums = new List<Auditorium>();
            for (int i = 1; i <= 6; i++)
            {
                _auditoriums.Add(new Auditorium { Id = i, Name = $"Zaal {i}" });
            }
            
             var today = DateTimeOffset.Now.Date;
             _showings = new List<ShowingsWithPricesResponse>
             {
                 new() { ShowingId = 1, MovieTitle = "Movie title", AuditoriumId = 1, Runtime = 150, StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 15, 0, 0, TimeSpan.Zero) },
                 new() { ShowingId = 2, MovieTitle = "Movie title", AuditoriumId = 2, Runtime = 150, StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 15, 0, 0, TimeSpan.Zero) },
                 new() { ShowingId = 3, MovieTitle = "Movie title", AuditoriumId = 3, Runtime = 150, StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 17, 0, 0, TimeSpan.Zero) },
                 new() { ShowingId = 6, MovieTitle = "Movie title", AuditoriumId = 4, Runtime = 150, StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 12, 30, 0, TimeSpan.Zero) },
                 new() { ShowingId = 9, MovieTitle = "Movie title", AuditoriumId = 5, Runtime = 150, StartsAt = new DateTimeOffset(today.Year, today.Month, today.Day, 14, 30, 0, TimeSpan.Zero) }
             };
        }

        _loading = false;
    }

    private double CalculateTopOffset(DateTimeOffset dateTime)
    {
        // De tijdlijn begint om 12:00. Elke 80px stelt 1 uur voor.
        var startHour = 12.0;
        var hourValue = dateTime.Hour + (dateTime.Minute / 60.0);
        var diff = hourValue - startHour;
        
        // We zorgen dat we niet boven de header uitkomen (negatieve offset)
        return Math.Max(0, diff * 80.0);
    }

    private double CalculateHeight(int? runtimeMinutes)
    {
        // 60 minuten = 80px
        if (!runtimeMinutes.HasValue || runtimeMinutes == 0) return 120; // Default
        return (runtimeMinutes.Value / 60.0) * 80.0;
    }

    private string GetStatusClass(ShowingsWithPricesResponse showing)
    {
        // Mock data logic gebaseerd op ID voor demo
        if (showing.ShowingId == 3 || showing.ShowingId == 6 || showing.ShowingId == 9) return "status-soldout";
        if (showing.ShowingId == 2) return "status-few";
        
        return "status-available";
    }

    private string GetStatusText(ShowingsWithPricesResponse showing)
    {
        if (showing.ShowingId == 3 || showing.ShowingId == 6 || showing.ShowingId == 9) return "Sold out";
        if (showing.ShowingId == 2) return "Few seats left";
        
        return "Seats available";
    }
}

@page "/MoviesToday"
@using SharedLibrary.DTOs.Responses
@using WA.Services.Http.Interfaces
@inject IMovieApiClient MovieApiClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using WA.Layout
@layout AdminLayout

<PageTitle>Movies Today</PageTitle>

@* ── Page header ── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Movies</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/admin/movies/add">
        Add Movie
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_loadError)
{
    <MudAlert Severity="Severity.Error">Failed to load movies. Please try again.</MudAlert>
}
else
{
    <MudDataGrid T="MovieResponse"
                 Items="_movies"
                 SortMode="SortMode.Multiple"
                 Hideable="true"
                 Dense="true"
                 Striped="true"
                 Hover="true"
                 Pageable="true"
                 PageSize="10"
                 QuickFilter="_quickFilter">
        <ToolBarContent>
            
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Search movies..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true"
                          Class="mt-0" />
            <MudSpacer />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Title"                     Title="Title" />
            <PropertyColumn Property="x => x.Language"                  Title="Language" />
            <PropertyColumn Property="x => x.Runtime"                   Title="Runtime (min)" />
            <PropertyColumn Property="x => x.ReleaseDate"               Title="Release Date" />
            <PropertyColumn Property="x => x.AgeIndication"             Title="Age Indication" />
            <PropertyColumn Property="x => x.SpokenLanguageCodeIso6391" Title="Language Code" />

            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" CellStyle="width: 120px; text-align: right;">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Title="Delete movie"
                                   OnClick="@(() => OpenDeleteDialog(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="MovieResponse" PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudDataGrid>
}

@* ── Delete confirmation dialog ── *@
<MudDialog @bind-Visible="_deleteDialogOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Class="mr-2" />
            Delete Movie
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            Are you sure you want to delete <strong>@_movieToDelete?.Title</strong>? This action cannot be undone.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">Cancel</MudButton>
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   OnClick="ConfirmDeleteAsync"
                   Disabled="_deleting">
            @if (_deleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Delete
        </MudButton>
    </DialogActions>
</MudDialog>

@if (_errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
        @_errorMessage
    </MudAlert>
}

@code {
    private List<MovieResponse> _movies = new();
    private bool _loading = true;
    private bool _loadError;

    private bool _deleteDialogOpen;
    private bool _deleting;
    private MovieResponse? _movieToDelete;
    private string? _errorMessage;

    private string _searchString = string.Empty;

    // Filters across title, language, release date and IMDB id
    private Func<MovieResponse, bool> _quickFilter => movie =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var s = _searchString.Trim();

        return movie.Title.Contains(s, StringComparison.OrdinalIgnoreCase)
            || (movie.Language?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
            || (movie.ReleaseDate?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
            || (movie.ImdbId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false);
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadMoviesAsync();
    }

    private async Task LoadMoviesAsync()
    {
        _loading = true;
        _loadError = false;

        var result = await MovieApiClient.GetAllMoviesAsync();

        if (result is null)
            _loadError = true;
        else
            _movies = result;

        _loading = false;
    }

    private void OpenDeleteDialog(MovieResponse movie)
    {
        _movieToDelete = movie;
        _deleteDialogOpen = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogOpen = false;
        _movieToDelete = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_movieToDelete is null) return;

        _deleting = true;
        var success = await MovieApiClient.DeleteMovieAsync(_movieToDelete.TmdbId);
        _deleting = false;

        if (success)
        {
            _movies.Remove(_movieToDelete);
            CloseDeleteDialog();
        }
        else
        {
            _errorMessage = $"Failed to delete \"{_movieToDelete.Title}\". Please try again.";
            CloseDeleteDialog();
        }
    }
}

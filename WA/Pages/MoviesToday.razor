@page "/today"
@using SharedLibrary.DTOs.Responses
@using WA.Services.Http.Interfaces
@inject IShowingApi ShowingApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using WA.Layout
@layout MainLayout

<PageTitle>Movies Today</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <MudText Typo="Typo.h4" Style="font-weight: bold; color: #BB86FC;">Movies Today</MudText>
    <MudText Typo="Typo.h6" Style="color: #03DAC6;">@DateTime.Now.ToString("dddd, dd MMMM yyyy HH:mm")</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_loadError)
{
    <MudAlert Severity="Severity.Error">Failed to load data. Please try again.</MudAlert>
}
else if (_showings.Count == 0)
{
    <MudAlert Severity="Severity.Info">No showings found for today.</MudAlert>
}
else
{
    <div class="today-showings-grid">
        @foreach (var showing in _showings.OrderBy(s => s.StartsAt))
        {
            var localStart = showing.StartsAt.ToLocalTime();

            <MudCard Elevation="4" Class="movie-card-today">
                <MudCardContent Class="pa-4">
                    <div class="d-flex justify-space-between align-start flex-wrap gap-2">
                        <div>
                            <MudText Typo="Typo.h6" Style="font-weight: bold; color: #121212;">
                                @showing.MovieTitle
                            </MudText>

                            <MudText Typo="Typo.body2" Class="mt-1" Style="color: #444; font-weight: 500;">
                                Start: @localStart.ToString("HH:mm")
                            </MudText>
                        </div>

                        <MudChip T="string"
                                 Size="Size.Medium"
                                 Color="Color.Primary"
                                 Variant="Variant.Filled">
                            Vandaag
                        </MudChip>
                    </div>

                    <MudDivider Class="my-3" />

                    <div class="prices-grid">
                        <div class="price-item">
                            <MudText Typo="Typo.caption" Style="color: #666;">Adult</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: #121212;">
                                € @showing.Prices.Adult.ToString("0.00")
                            </MudText>
                        </div>

                        <div class="price-item">
                            <MudText Typo="Typo.caption" Style="color: #666;">Child</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: #121212;">
                                € @showing.Prices.Child.ToString("0.00")
                            </MudText>
                        </div>

                        <div class="price-item">
                            <MudText Typo="Typo.caption" Style="color: #666;">Student</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: #121212;">
                                € @showing.Prices.Student.ToString("0.00")
                            </MudText>
                        </div>

                        <div class="price-item">
                            <MudText Typo="Typo.caption" Style="color: #666;">Senior</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: #121212;">
                                € @showing.Prices.Senior.ToString("0.00")
                            </MudText>
                        </div>
                    </div>
                </MudCardContent>
            </MudCard>
        }
    </div>
}

<style>
    .today-showings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 16px;
    }

    .movie-card-today {
        background-color: #D1D5DB !important;
        color: #121212 !important;
        border-radius: 12px;
    }

    .prices-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(120px, 1fr));
        gap: 12px;
    }

    .price-item {
        background-color: rgba(255, 255, 255, 0.5);
        border-radius: 8px;
        padding: 10px 12px;
    }
</style>

@code {
    private List<ShowingsWithPricesResponse> _showings = new();
    private bool _loading = true;
    private bool _loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = false;

        try
        {
            var allShowings = await ShowingApi.GetShowingsWithPricesAsync();

            var today = DateTimeOffset.Now.Date;
            _showings = allShowings
                .Where(s => s.StartsAt.ToLocalTime().Date == today)
                .OrderBy(s => s.StartsAt)
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError = true;
            Console.WriteLine($"Error loading data: {ex.Message}");
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}

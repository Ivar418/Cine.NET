@page "/showings"

@using SharedLibrary.DTOs.Responses
@using WA.Services.Http.Interfaces
@using MudBlazor

@inject IShowingApi ShowingApi

<MudText Typo="Typo.h4" GutterBottom="true" Style="color: var(--mud-palette-text-secondary);">Showings</MudText>

<MudTable Items="_showings" Dense="true" Class="white-datagrid">
    <HeaderContent>
        <MudTh>Showing</MudTh>
        <MudTh>Film</MudTh>
        <MudTh>Adult</MudTh>
        <MudTh>Child</MudTh>
        <MudTh>Student</MudTh>
        <MudTh>Senior</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.ShowingId</MudTd>
        <MudTd>@context.MovieTitle</MudTd>

        <MudTd Class="@(context.Prices.Adult.IsAvailable ? "" : "0.4")">
            @context.Prices.Adult.Price.ToString("C")
        </MudTd>

        <MudTd Class="@(context.Prices.Child.IsAvailable ? "" : "0.4")">
            @context.Prices.Child.Price.ToString("C")
        </MudTd>

        <MudTd Class="@(context.Prices.Student.IsAvailable ? "" : "0.4")">
            @context.Prices.Student.Price.ToString("C")
        </MudTd>

        <MudTd Class="@(context.Prices.Senior.IsAvailable ? "" : "0.4")">
            @context.Prices.Senior.Price.ToString("C")
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private IReadOnlyList<ShowingsWithPricesResponse> _showings = [];

    protected override async Task OnInitializedAsync()
    {
        _showings = await ShowingApi.GetShowingsWithPricesAsync();
    }
}
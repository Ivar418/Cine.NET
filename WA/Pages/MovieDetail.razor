@page "/moviedetails/{MovieId:int}/{ShowingId:int}"
@inject IMovieApiClient MovieApi
@inject NavigationManager Nav
@using SharedLibrary.DTOs.Responses
@using WA.Services.Http.Interfaces
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-16">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_movie == null)
    {
        <MudAlert Severity="Severity.Error">Movie not found.</MudAlert>
    }
    else
    {
        <MudPaper Elevation="3" Class="pa-6">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudImage
                        Src="@PosterUrl"
                        Alt="@_movie.Title"
                        ObjectFit="ObjectFit.Cover"
                        Style="width: 100%; border-radius: 8px;" />
                </MudItem>
                <MudItem xs="12" md="8">

                    <MudText
                        Typo="Typo.h4"
                        Style="color: var(--mud-palette-text-secondary); font-weight: 700;"
                        Class="mb-4">
                        @_movie.Title
                    </MudText>
                    <div class="white-text">
                        <MudText><strong>Runtime:</strong> @_movie.Runtime min</MudText>
                        <MudText><strong>Release date:</strong> @_movie.ReleaseDate</MudText>
                        <MudText><strong>Age indication:</strong> @(_movie.AgeIndication ?? "Unknown")</MudText>
                        <MudText><strong>Language:</strong> @(_movie.SpokenLanguageName ?? "Unknown")</MudText>
                    </div>

                    <MudDivider Class="my-4" />
                    <div class="white-text">
                        <MudText><strong>Start time:</strong> @_showing?.StartTime</MudText>
                        <MudText><strong>End time:</strong> @_showing?.EndTime</MudText>
                        <MudText><strong>Auditorium:</strong> @_showing?.AuditoriumName</MudText>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1">
                            <MudText><strong>Wheelchair accessible:</strong></MudText>
                            @if (_showing?.WheelchairAccessible == true)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                            }
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1">
                            <MudText><strong>3D:</strong></MudText>
                            @if (_showing?.Is3DCompatible == true)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                            }
                        </MudStack>
                    </div>
                    <MudButton
                        Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Large"
                        Class="mt-6"
                        OnClick="NavigateToOrder">
                        Order Tickets
                    </MudButton>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-6" />
            <MudText
                Typo="Typo.h4"
                Style="color: var(--mud-palette-text-secondary); font-weight: 700;"
                Class="mb-3">
                Description
            </MudText>
            <MudText class="white-text">@(_movie.About ?? "No description available.")</MudText>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public int MovieId { get; set; }
    [Parameter] public int ShowingId { get; set; }

    private MovieResponse? _movie;
    private MockShowing? _showing;
    private bool _loading = true;

    private string PosterUrl => $"https://image.tmdb.org/t/p/w500{_movie?.PosterUrl}";

    protected override async Task OnInitializedAsync()
    {
        _movie = await MovieApi.GetMovieByIdAsync(MovieId);

        _showing = new MockShowing
        {
            StartTime = "20:00",
            EndTime = "22:15",
            AuditoriumName = "Zaal 3",
            WheelchairAccessible = true,
            Is3DCompatible = false
        };

        _loading = false;
    }

    private void NavigateToOrder()
    {
        Nav.NavigateTo($"/ideal-mock?reference=76328&amount=36.00&merchant=Cine.NET&description=Filmtickets");
    }

    private class MockShowing
    {
        public string StartTime { get; set; } = string.Empty;
        public string EndTime { get; set; } = string.Empty;
        public string AuditoriumName { get; set; } = string.Empty;
        public bool WheelchairAccessible { get; set; }
        public bool Is3DCompatible { get; set; }
    }
}
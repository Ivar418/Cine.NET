@page "/seat-finder"
@using SharedLibrary.DTOs.Models
@using WA.Services.Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable
@inject ISeatFinderApiClient Api

<PageTitle>Cinema Reservering</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudStack Spacing="4">

        @* ── Showing selector ────────────────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.End" Spacing="3">

                <MudStack Spacing="1" Style="min-width:260px">
                    <MudText Typo="Typo.caption" Style="letter-spacing:.1em;color:var(--mud-palette-text-secondary)">VOORSTELLING</MudText>
                    @if (_Showings is null)
                    {
                        <MudSkeleton Width="260px" Height="40px" />
                    }
                    else
                    {
                        <MudSelect T="int?" Value="_ShowingId" ValueChanged="OnShowingChangedAsync"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Placeholder="Kies een voorstelling…">
                            @foreach (var s in _Showings)
                            {
                                <MudSelectItem Value="(int?)s.Id">
                                    @s.Movie.Title — @s.StartsAt.LocalDateTime.ToString("dd MMM HH:mm") (@s.Auditorium.Name)
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                </MudStack>

                @if (_state is not null)
                {
                    @* Normal tickets *@
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Style="letter-spacing:.1em;color:var(--mud-palette-text-secondary)">🪑 NORMAAL</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="() => _normalCount = Math.Max(0, _normalCount - 1)" />
                            <MudText Style="min-width:28px;text-align:center;font-weight:700;font-size:1.1rem">@_normalCount</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Add"    Size="Size.Small" OnClick="() => _normalCount++" />
                        </MudStack>
                    </MudStack>

                    @* Wheelchair tickets *@
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Style="letter-spacing:.1em;color:var(--mud-palette-text-secondary)">♿ ROLSTOEL</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="() => _wcCount = Math.Max(0, _wcCount - 1)" />
                            <MudText Style="min-width:28px;text-align:center;font-weight:700;font-size:1.1rem;color:#93c5fd">@_wcCount</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Add"    Size="Size.Small" OnClick="() => _wcCount++" />
                        </MudStack>
                    </MudStack>

                    @* Zones *@
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Style="letter-spacing:.1em;color:var(--mud-palette-text-secondary)">ZONES</MudText>
                        <MudSwitch T="bool" @bind-Value="_showZones" Color="Color.Success" />
                    </MudStack>

                    @* Actions *@
                    <MudStack Row="true" Spacing="1" Class="ml-auto" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="SuggestAsync"
                                   Disabled="@(_normalCount + _wcCount == 0 || _busy)">
                            Zoek @(_normalCount + _wcCount) @(_normalCount + _wcCount == 1 ? "plek" : "plekken")
                        </MudButton>
                        @if (_pendingId.HasValue)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       OnClick="ConfirmAsync">Bevestig</MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Close"
                                       OnClick="CancelPendingAsync">Annuleer</MudButton>
                        }
                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="ResetAsync">Reset</MudButton>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        @* ── Seat grid ───────────────────────────────────────────────── *@
        @if (_busy && _state is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_state is not null)
        {
            <MudPaper Elevation="2" Class="pa-3" Style="overflow-x:auto">
                @* Film/Auditorium info strip *@
                <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                    <MudChip T="string" Color="Color.Dark" Size="Size.Small"
                             Icon="@Icons.Material.Filled.Movie">
                        @_state.Showing.Movie.Title
                    </MudChip>
                    <MudChip T="string" Color="Color.Dark" Size="Size.Small"
                             Icon="@Icons.Material.Filled.Schedule">
                        @_state.Showing.StartsAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")
                    </MudChip>
                    <MudChip T="string" Color="Color.Dark" Size="Size.Small"
                             Icon="@Icons.Material.Filled.EventSeat">
                        @_state.Showing.Auditorium.Name
                    </MudChip>
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
                        @(_state.AllSeats.Count - _state.OccupiedKeys.Count) vrije plekken
                    </MudText>
                </MudStack>

                <SeatGrid Auditorium="@(new AuditoriumDto(_state.Showing.Auditorium.Id, _state.Showing.Auditorium.Name, _state.Showing.Auditorium.Rows))"
                          AllSeats="@_state.AllSeats"
                          OccupiedKeys="@_state.OccupiedKeys"
                          SuggestedKeys="@_suggestedKeys"
                          ShowZones="@_showZones" />
            </MudPaper>
        }
        else if (_ShowingId.HasValue)
        {
            <MudAlert Severity="Severity.Warning">Kan voorstelling niet laden.</MudAlert>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-6" Style="text-align:center">
                <MudText Style="color:var(--mud-palette-text-secondary);letter-spacing:.15em">
                    Selecteer een voorstelling om te beginnen
                </MudText>
            </MudPaper>
        }

        @* ── Legend ──────────────────────────────────────────────────── *@
        @if (_state is not null)
        {
            <MudPaper Elevation="1" Class="pa-3">
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Justify="Justify.Center">
                    @foreach (var (label, color) in _legend)
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Style="@($"background:{color}22;border:1px solid {color}66;color:{color};font-size:.65rem")">
                            @label
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }

    </MudStack>
</MudContainer>

@code {
    private List<Showing>?  _Showings;
    private ShowingStateDto?   _state;
    private int?                _ShowingId;
    private bool                _busy      = false;
    private bool                _showZones = true;
    private int                 _normalCount = 2;
    private int                 _wcCount     = 0;
    private HashSet<string>     _suggestedKeys = [];
    private Guid?               _pendingId;

    protected override async Task OnInitializedAsync()
    {
        _Showings = await Api.GetShowingsAsync();
    }

    public void Dispose() { }

    // ── Showing selection ────────────────────────────────────────────────
    private async Task OnShowingChangedAsync(int? id)
    {
        await CancelPendingAsync();
        _ShowingId    = id;
        _state         = null;
        _suggestedKeys = [];
        _pendingId     = null;

        if (id.HasValue)
        {
            _busy  = true;
            _state = await Api.GetShowingStateAsync(id.Value);
            _busy  = false;
        }
    }

    // ── Suggest ───────────────────────────────────────────────────────────
    private async Task SuggestAsync()
    {
        if (!_ShowingId.HasValue || _normalCount + _wcCount == 0) return;
        await CancelPendingAsync();
        _busy = true;

        var resp = await Api.SuggestAsync(new SuggestRequest(_ShowingId.Value, _normalCount, _wcCount));
        _busy = false;

        if (resp is null || !resp.Found)
        {
            Snackbar.Add("Geen geschikte plekken beschikbaar.", Severity.Warning);
            return;
        }

        _pendingId     = resp.SuggestionId;
        _suggestedKeys = resp.Seats.Select(s => $"{s.Row}-{s.Col}").ToHashSet();

        // Optimistically mark suggested seats as occupied in the local state
        if (_state is not null)
            foreach (var k in _suggestedKeys)
                _state.OccupiedKeys.Add(k);

        double avgCat = resp.Seats.Average(s => s.Category);
        Snackbar.Add($"{resp.Seats.Count} plekken gevonden (gem. cat. {avgCat:F1}). Bevestig of annuleer.", Severity.Info);
    }

    // ── Confirm ───────────────────────────────────────────────────────────
    private async Task ConfirmAsync()
    {
        if (!_pendingId.HasValue) return;
        var res = await Api.ConfirmAsync(_pendingId.Value);
        if (res is null) { Snackbar.Add("Bevestiging mislukt.", Severity.Error); return; }

        _pendingId     = null;
        _suggestedKeys = [];
        // Refresh state from server to get accurate picture
        if (_ShowingId.HasValue)
            _state = await Api.GetShowingStateAsync(_ShowingId.Value);

        Snackbar.Add("Reservering bevestigd!", Severity.Success);
    }

    // ── Cancel ────────────────────────────────────────────────────────────
    private async Task CancelPendingAsync()
    {
        if (!_pendingId.HasValue) return;
        await Api.CancelAsync(_pendingId.Value);

        // Remove optimistic occupation
        if (_state is not null)
            foreach (var k in _suggestedKeys)
                _state.OccupiedKeys.Remove(k);

        _pendingId     = null;
        _suggestedKeys = [];
    }

    private async Task ResetAsync()
    {
        await CancelPendingAsync();
        if (_ShowingId.HasValue)
            _state = await Api.GetShowingStateAsync(_ShowingId.Value);
    }

    // ── Legend ────────────────────────────────────────────────────────────
    private static readonly (string, string)[] _legend =
    [
        ("1e keuze", "#f59e0b"), ("2e keuze", "#a3e635"), ("3e keuze", "#34d399"),
        ("4e keuze", "#60a5fa"), ("5e keuze", "#c084fc"), ("6e keuze", "#f87171"),
        ("Suggestie ★", "#fbbf24"), ("Bevestigd ✓", "#22c55e"),
        ("Bezet", "#3f3f46"),    ("Rolstoel ♿", "#1d4ed8"),
    ];
}

@page "/admin/reservations/payment-result"
@using WA.Layout
@using WA.Services.Http.Interfaces
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@layout AdminLayout

@inject IOrderApi OrderApi
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    @if (_loading)
    {
        <MudPaper Class="pa-6">
            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText>Betaling verwerken...</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/reservations" Class="mt-3">
            Terug naar reserveringen
        </MudButton>
    }
    else
    {
        <MudAlert Severity="Severity.Success">
            Betaling bevestigd en tickets zijn gegenereerd.
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/reservations" Class="mt-3">
            Terug naar reserveringen
        </MudButton>
    }
</MudContainer>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "orderId")]
    public int OrderId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "success")]
    public bool Success { get; set; }

    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (OrderId <= 0)
        {
            _error = "Ongeldig orderId.";
            _loading = false;
            return;
        }

        if (!Success)
        {
            _error = "Betaling is niet succesvol afgerond in de iDEAL mock.";
            _loading = false;
            return;
        }

        var confirmed = await OrderApi.ConfirmPaymentAsync(OrderId);
        if (confirmed is null)
        {
            _error = "Kon betaling niet bevestigen op de server.";
            _loading = false;
            return;
        }

        var pdf = await OrderApi.GetTicketsPdfAsync(OrderId);
        if (pdf is null)
        {
            _error = "Betaling bevestigd, maar tickets PDF kon niet worden opgehaald.";
            _loading = false;
            return;
        }

        var base64 = Convert.ToBase64String(pdf);
        await JS.InvokeVoidAsync("downloadBase64Pdf", base64, $"tickets-{confirmed.OrderCode}.pdf");
        Snackbar.Add($"Order {confirmed.OrderCode} is betaald en tickets zijn gedownload.", Severity.Success);

        _loading = false;
    }
}
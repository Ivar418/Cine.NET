@page "/admin/movies/add"
@using SharedLibrary.DTOs.Responses.TMDB
@using WA.Services.Http.Interfaces
@inject IMovieApiClient MovieApiClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using WA.Layout
@layout AdminLayout

<PageTitle>Admin — Add Movie</PageTitle>

@* ── Page header ── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                   Variant="Variant.Text"
                   Color="Color.Default"
                   Href="/admin/movies"
                   Title="Back to movies"/>
    <MudText Typo="Typo.h4" Style="color: var(--mud-palette-text-secondary);">Add Movie</MudText>
</MudStack>

@* ── Search bar ── *@
<MudPaper Elevation="1" Class="pa-4 mb-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudTextField @bind-Value="_query"
                      Label="Search TMDB"
                      Placeholder="e.g. The Godfather"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="false"
                      OnKeyDown="HandleKeyDown"
                      Class="flex-grow-1 white-text"
                      Disabled="_searching"/>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="SearchAsync"
                   Disabled="@(_searching || string.IsNullOrWhiteSpace(_query))"
                   Style="height: 56px; min-width: 120px;">
            @if (_searching)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Searching…</span>
            }
            else
            {
                <span>Search</span>
            }
        </MudButton>
    </MudStack>
</MudPaper>

@* ── Search error ── *@
@if (_searchError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Failed to fetch search results. Please check your connection and try again.
    </MudAlert>
}

@* ── No results ── *@
@if (!_searching && _hasSearched && (_results is null || _results.Count == 0) && !_searchError)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No movies found for "<strong>@_lastQuery</strong>". Try a different search term.
    </MudAlert>
}

@* ── Results list ── *@
@if (_results is { Count: > 0 })
{
    <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-primary">
        Showing @_results.Count of @_totalResults result@(_totalResults == 1 ? "" : "s") for
        "<strong>@_lastQuery</strong>"
    </MudText>

    <MudList T="MovieSearchItemDto" DisablePadding="true">
        @foreach (var movie in _results)
        {
            <MudPaper Elevation="1" Class="mb-3 pa-0" Style="overflow: hidden;">
                <MudStack Row="true" AlignItems="AlignItems.Stretch" Spacing="0">

                    @* ── Poster ── *@
                    <div
                        style="width: 80px; min-height: 120px; flex-shrink: 0; background: #F5F5F5; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(movie.PosterPath))
                        {
                            <img src="https://image.tmdb.org/t/p/w200@(movie.PosterPath)"
                                 alt="@movie.Title poster"
                                 style="width: 80px; height: 120px; object-fit: cover; display: block;"/>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Movie"
                                     Style="font-size: 2.5rem; color: var(--mud-palette-text-disabled);"/>
                        }
                    </div>

                    @* ── Info ── *@
                    <div style="flex: 1; padding: 12px 16px; min-width: 0;">
                        <MudText Typo="Typo.h6" Class="white-text" Style="line-height: 1.3;">@movie.Title</MudText>

                        @if (!string.IsNullOrEmpty(movie.ReleaseDate))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 white-text">
                                @movie.ReleaseDate[..4]
                                &nbsp;·&nbsp;
                                <MudIcon Icon="@Icons.Material.Filled.Star"
                                         Style="font-size: 0.85rem; vertical-align: middle; color: var(--mud-palette-warning);"/>
                                @movie.VoteAverage.ToString("F1")
                            </MudText>
                        }

                        @if (!string.IsNullOrEmpty(movie.Overview))
                        {
                            <MudText Typo="Typo.body2"
                                     Style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;" Class="white-text" >
                                @movie.Overview
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="white-text" ><em>No description available.</em>
                            </MudText>
                        }
                    </div>

                    @* ── Add button ── *@
                    <div style="display: flex; align-items: center; padding: 12px;">
                        @if (_addingId == movie.Id)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary"/>
                        }
                        else
                        {
                            <MudTooltip Text="Add to system">
                                <MudIconButton Icon="@Icons.Material.Filled.AddCircle"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               Disabled="_addingId.HasValue"
                                               OnClick="@(() => AddMovieAsync(movie))"
                                               Title="Add movie"/>
                            </MudTooltip>
                        }
                    </div>

                </MudStack>
            </MudPaper>
        }
    </MudList>

    @* ── Load more ── *@
    @if (_currentPage < _totalPages)
    {
        <div class="d-flex justify-center mt-2 mb-6">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ExpandMore"
                       OnClick="LoadMoreAsync"
                       Disabled="_loadingMore"
                       Style="min-width: 200px;">
                @if (_loadingMore)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                    <span>Loading…</span>
                }
                else
                {
                    <span>Load more results</span>
                }
            </MudButton>
        </div>
    }
    else if (_hasSearched && _totalPages > 1)
    {
        <div class="d-flex justify-center mt-2 mb-6">
            <MudText Typo="Typo.caption" Color="Color.Secondary">All @_totalResults results loaded.</MudText>
        </div>
    }
}

@code {
    private string _query = string.Empty;
    private string _lastQuery = string.Empty;

    private bool _searching;
    private bool _loadingMore;
    private bool _hasSearched;
    private bool _searchError;

    private List<MovieSearchItemDto>? _results;
    private int? _addingId;

// Pagination state
    private int _currentPage;
    private int _totalPages;
    private int _totalResults;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_query) && !_searching)
            await SearchAsync();
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;

        _searching = true;
        _searchError = false;
        _hasSearched = false;
        _results = null;
        _currentPage = 0;
        _totalPages = 0;
        _totalResults = 0;
        _lastQuery = _query.Trim();

        var result = await MovieApiClient.SearchTmdbAsync(_lastQuery, page: 1);

        _hasSearched = true;
        _searching = false;

        if (result is null)
        {
            _searchError = true;
        }
        else
        {
            _results = result.Results;
            _currentPage = result.Page;
            _totalPages = result.TotalPages;
            _totalResults = result.TotalResults;
        }
    }

    private async Task LoadMoreAsync()
    {
        if (_loadingMore || _currentPage >= _totalPages) return;

        _loadingMore = true;

        var result = await MovieApiClient.SearchTmdbAsync(_lastQuery, page: _currentPage + 1);

        _loadingMore = false;

        if (result is not null)
        {
            _results ??= new List<MovieSearchItemDto>();
            _results.AddRange(result.Results);
            _currentPage = result.Page;
            _totalPages = result.TotalPages;
            _totalResults = result.TotalResults;
        }
        else
        {
            Snackbar.Add("Failed to load more results. Please try again.", Severity.Warning);
        }
    }

    private async Task AddMovieAsync(MovieSearchItemDto movie)
    {
        _addingId = movie.Id;

        var (success, errorMessage, _) = await MovieApiClient.AddMovieFromTmdbAsync(movie.Id);

        _addingId = null;

        if (success)
        {
            Snackbar.Add($"{movie.Title} was successfully added!", Severity.Success);
            Navigation.NavigateTo("/admin/movies");
        }
        else
        {
            Snackbar.Add(errorMessage ?? "Failed to add movie.", Severity.Error);
        }
    }

}

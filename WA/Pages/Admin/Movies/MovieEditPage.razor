@page "/admin/movies/{Id:int}/edit"
@inject NavigationManager Navigation

<PageTitle>Admin — Edit Movie</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Edit Movie</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">@_movie?.Title</MudText>

@if (_movie is null)
{
    <MudAlert Severity="Severity.Error">Movie not found.</MudAlert>
}
else
{
    <EditForm Model="_movie" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />

        @* ── General ── *@
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">General</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_movie.Title"
                                      Label="Title"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_movie.Language"
                                      Label="Language"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_movie.About"
                                      Label="About"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      FullWidth="true" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @* ── Release Info ── *@
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Release Info</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_movie.ReleaseDate"
                                      Label="Release Date"
                                      Placeholder="YYYY-MM-DD"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudNumericField @bind-Value="_movie.Runtime"
                                         Label="Runtime (min)"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_movie.AgeIndication"
                                      Label="Age Indication"
                                      Placeholder="e.g. PG-13"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @* ── Language ── *@
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Language</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_movie.SpokenLanguageName"
                                      Label="Spoken Language Name"
                                      Placeholder="e.g. English"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_movie.SpokenLanguageCodeIso6391"
                                      Label="Spoken Language Code (ISO 639-1)"
                                      Placeholder="e.g. en"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
        
        @* ── Actions ── *@
        <MudStack Row="true" Spacing="2">
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_saving"
                       StartIcon="@Icons.Material.Filled.Save">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/admin/movies"))">
                Cancel
            </MudButton>
        </MudStack>

    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _saving;

    // ── Temporary local model (remove once MovieDto is available) ──
    private class MovieModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string? Language { get; set; }
        public string? PosterUrl { get; set; }
        public int? Runtime { get; set; }
        public string? ImdbId { get; set; }
        public string? ReleaseDate { get; set; }
        public string? About { get; set; }
        public string? AgeIndication { get; set; }
        public string? SpokenLanguageName { get; set; }
        public string? SpokenLanguageCodeIso6391 { get; set; }
    }

    // ── Hardcoded seed data — mirrors Movies.razor (replace with API call later) ──
    private static readonly List<MovieModel> SeedMovies = new()
    {
        new MovieModel { Id = 1, Title = "Inception",       Language = "English",  Runtime = 148, ReleaseDate = "2010-07-16", AgeIndication = "PG-13", SpokenLanguageCodeIso6391 = "en", SpokenLanguageName = "English",  ImdbId = "tt1375666" },
        new MovieModel { Id = 2, Title = "Parasite",        Language = "Korean",   Runtime = 132, ReleaseDate = "2019-05-30", AgeIndication = "R",     SpokenLanguageCodeIso6391 = "ko", SpokenLanguageName = "Korean",   ImdbId = "tt6751668" },
        new MovieModel { Id = 3, Title = "The Dark Knight", Language = "English",  Runtime = 152, ReleaseDate = "2008-07-18", AgeIndication = "PG-13", SpokenLanguageCodeIso6391 = "en", SpokenLanguageName = "English",  ImdbId = "tt0468569" },
        new MovieModel { Id = 4, Title = "Amélie",          Language = "French",   Runtime = 122, ReleaseDate = "2001-04-25", AgeIndication = "R",     SpokenLanguageCodeIso6391 = "fr", SpokenLanguageName = "French",   ImdbId = "tt0211915" },
        new MovieModel { Id = 5, Title = "Interstellar",    Language = "English",  Runtime = 169, ReleaseDate = "2014-11-07", AgeIndication = "PG-13", SpokenLanguageCodeIso6391 = "en", SpokenLanguageName = "English",  ImdbId = "tt0816692" },
        new MovieModel { Id = 6, Title = "Spirited Away",   Language = "Japanese", Runtime = 125, ReleaseDate = "2001-07-20", AgeIndication = "PG",    SpokenLanguageCodeIso6391 = "ja", SpokenLanguageName = "Japanese", ImdbId = "tt0245429" },
    };

    private MovieModel? _movie;

    protected override void OnParametersSet()
    {
        // Clone the seed record so edits don't mutate the source list
        var found = SeedMovies.FirstOrDefault(m => m.Id == Id);
        _movie = found is null ? null : new MovieModel
        {
            Id                        = found.Id,
            Title                     = found.Title,
            Language                  = found.Language,
            PosterUrl                 = found.PosterUrl,
            Runtime                   = found.Runtime,
            ImdbId                    = found.ImdbId,
            ReleaseDate               = found.ReleaseDate,
            About                     = found.About,
            AgeIndication             = found.AgeIndication,
            SpokenLanguageName        = found.SpokenLanguageName,
            SpokenLanguageCodeIso6391 = found.SpokenLanguageCodeIso6391,
        };
    }

    private async Task HandleSave()
    {
        _saving = true;

        // TODO: replace with API call when backend is ready
        // await MovieApiClient.UpdateMovieAsync(_movie.Id, _movie);
        await Task.Delay(600); // Simulates network latency

        _saving = false;
        Navigation.NavigateTo("/admin/movies");
    }
}
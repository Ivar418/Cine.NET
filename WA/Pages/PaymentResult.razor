@page "/checkout/payment-result"
@namespace WA.Pages
@using SharedLibrary.DTOs.Responses
@using WA.Services.Http
@using WA.Services.Http.Interfaces
@inject IOrderApi OrderApi
@inject ISeatFinderApiClient SeatFinderApiClient
@inject NavigationManager Nav
@inject IJSRuntime JS
<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudProgressCircular Indeterminate="true" Size="Size.Large"/>
            <MudText Typo="Typo.h6">@(Reservation ? "Reservering verwerken..." : "Betaling verwerken...")</MudText>
        </MudStack>
    }
    else if (_success && _order is not null)
    {
        <MudPaper Class="pa-6" Elevation="3">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:4rem"/>
                <MudText Typo="Typo.h5">@(Reservation ? "Reservering geslaagd!" : "Betaling geslaagd!")</MudText>
                <MudText Typo="Typo.body1">Bestelling <strong>@_order.OrderCode</strong>
                    is @(Reservation ? "geregistreerd" : "bevestigd").
                </MudText>
                @if (!Reservation)
                {
                    <MudText Typo="Typo.body2">Totaal betaald: <strong>€@_order.TotalAmount.ToString("F2")</strong>
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2">Totaal te betalen aan de kassa:
                        <strong>€@_order.TotalAmount.ToString("F2")</strong></MudText>
                }
                <MudDivider Class="my-2" Style="width:100%"/>
                <MudText
                    Typo="Typo.body2">@(Reservation ? "Uw reserveringsbewijs is gedownload." : "Uw tickets worden automatisch gedownload.")</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="DownloadAsync">
                    @(Reservation ? "Reservering opnieuw downloaden" : "Tickets opnieuw downloaden")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           OnClick="() => ReturnToProperPage()">
                    @(FromAdmin ? "Terug naar reserveringen" : "Terug naar home")
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="3">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="font-size:4rem"/>
                <MudText Typo="Typo.h5">@(Reservation ? "Reservering mislukt" : "Betaling mislukt")</MudText>
                <MudText
                    Typo="Typo.body1">@(Reservation ? "De reservering kon niet worden voltooid." : "De betaling is niet geslaagd of geannuleerd.")</MudText>
                <MudText Typo="Typo.caption" Class="mt-1">
                    U wordt automatisch teruggestuurd...
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           OnClick="ReturnToProperPage">
                    @(FromAdmin ? "Terug naar reserveringen" : "Terug naar betaling")
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter, SupplyParameterFromQuery] public int OrderId { get; set; }
    [Parameter, SupplyParameterFromQuery] public bool Success { get; set; }
    [Parameter, SupplyParameterFromQuery] public bool Reservation { get; set; }
    [Parameter, SupplyParameterFromQuery] public bool FromAdmin { get; set; }
    [Parameter, SupplyParameterFromQuery] public int ShowingId { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? PaymentMethod { get; set; }
    [Parameter, SupplyParameterFromQuery] public Guid? ReservationId { get; set; } = null;


    private bool _loading = true;
    private bool _success = false;
    private CreateOrderResponse? _order;
    private bool _autoRedirectScheduled = false;

    protected override async Task OnInitializedAsync()
    {
        if (OrderId <= 0)
        {
            _loading = false;
            return;
        }

        if (Reservation)
        {
            var order = await OrderApi.GetOrderAsync(OrderId);
            if (order is not null)
            {
                _order = order;
                _success = true;
                // Reservation PDF is already downloaded in Checkout.razor.cs, 
                // but we can ensure it's available here too if needed.
            }
        }
        else if (Success)
        {
            // Confirm payment on the backend
            var confirmed = await OrderApi.ConfirmPaymentAsync(OrderId);
            if (confirmed is not null)
            {
                _order = confirmed;
                _success = true;
                // Auto-download tickets PDF
                await DownloadAsync();
            }
        }

        _loading = false;
        // Failed/cancelled/expired/open => auto return after short delay
        if (!_success && !_autoRedirectScheduled)
        {
            if (ReservationId != null)
            {
               await SeatFinderApiClient.CancelAsync(ReservationId.Value); // best effort to free up reserved seats
            }
            _autoRedirectScheduled = true;
            _ = AutoRedirectAfterFailureAsync();
        }
    }

    private void ReturnToProperPage()
    {
        if (FromAdmin)
        {
            Nav.NavigateTo("/admin/reservations");
            return;
        }

        if (ShowingId > 0)
        {
            var method = Uri.EscapeDataString(PaymentMethod ?? string.Empty);
            Nav.NavigateTo($"/checkout/{ShowingId}?step=4&paymentMethod={method}");
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task DownloadAsync()
    {
        if (OrderId <= 0) return;

        byte[]? pdf;
        string fileName;

        if (Reservation)
        {
            pdf = await OrderApi.GetReservationPdfAsync(OrderId);
            fileName = $"reservering-{OrderId}.pdf";
        }
        else
        {
            pdf = await OrderApi.GetTicketsPdfAsync(OrderId);
            fileName = $"tickets-{OrderId}.pdf";
        }

        if (pdf is not null)
        {
            var base64 = Convert.ToBase64String(pdf);
            await JS.InvokeVoidAsync("downloadBase64Pdf", base64, fileName);
        }
    }

    private async Task AutoRedirectAfterFailureAsync()
    {
        // show failure popup for a few seconds
        await Task.Delay(3000);

        if (FromAdmin)
        {
            Nav.NavigateTo("/admin/reservations");
            return;
        }

        // customer: go back to payment-choice step, keep chosen payment if available
        if (ShowingId > 0)
        {
            var method = Uri.EscapeDataString(PaymentMethod ?? string.Empty);
            Nav.NavigateTo($"/checkout/{ShowingId}");
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

}
@page "/checkout/payment-result"
@namespace WA.Pages
@using SharedLibrary.DTOs.Responses
@using WA.Services.Http.Interfaces
@inject IOrderApi OrderApi
@inject NavigationManager Nav
@inject IJSRuntime JS
<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6">Betaling verwerken...</MudText>
        </MudStack>
    }
    else if (_success && _order is not null)
    {
        <MudPaper Class="pa-6" Elevation="3">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:4rem" />
                <MudText Typo="Typo.h5">Betaling geslaagd!</MudText>
                <MudText Typo="Typo.body1">Bestelling <strong>@_order.OrderCode</strong> is bevestigd.</MudText>
                <MudText Typo="Typo.body2">Totaal betaald: <strong>€@_order.TotalAmount.ToString("F2")</strong></MudText>
                <MudDivider Class="my-2" Style="width:100%" />
                <MudText Typo="Typo.body2">Uw tickets worden automatisch gedownload.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="DownloadTicketsAsync">
                    Tickets opnieuw downloaden
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           OnClick='() => Nav.NavigateTo("/")'>
                    Terug naar home
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="3">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="font-size:4rem" />
                <MudText Typo="Typo.h5">Betaling mislukt</MudText>
                <MudText Typo="Typo.body1">De betaling is niet geslaagd of geannuleerd.</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           OnClick='() => Nav.NavigateTo("/")'>
                    Terug naar home
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>
@code {
    [Parameter, SupplyParameterFromQuery] public int OrderId { get; set; }
    [Parameter, SupplyParameterFromQuery] public bool Success { get; set; }
    private bool _loading = true;
    private bool _success = false;
    private CreateOrderResponse? _order;
    protected override async Task OnInitializedAsync()
    {
        if (!Success || OrderId <= 0)
        {
            _loading = false;
            return;
        }
        // Confirm payment on the backend
        var confirmed = await OrderApi.ConfirmPaymentAsync(OrderId);
        if (confirmed is not null)
        {
            _order = confirmed;
            _success = true;
            // Auto-download tickets PDF
            await DownloadTicketsAsync();
        }
        _loading = false;
    }
    private async Task DownloadTicketsAsync()
    {
        if (OrderId <= 0) return;
        var pdf = await OrderApi.GetTicketsPdfAsync(OrderId);
        if (pdf is not null)
        {
            var base64 = Convert.ToBase64String(pdf);
            await JS.InvokeVoidAsync("downloadBase64Pdf", base64, $"tickets-{OrderId}.pdf");
        }
    }
}